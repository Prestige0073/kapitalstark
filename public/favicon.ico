<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="48" height="48">
  <!-- Background -->
  <rect width="48" height="48" rx="10" fill="#F5F8FF"/>
  <rect width="48" height="48" rx="10" fill="none" stroke="#267BF1" stroke-width="1.5" stroke-opacity="0.18"/>

  <!-- K — italic serif (Playfair Display approx via Georgia) -->
  <text
    x="4" y="35"
    font-family="Georgia, 'Playfair Display', 'Times New Roman', serif"
    font-style="italic"
    font-weight="700"
    font-size="30"
    fill="#0D1B2A">K</text>

  <!-- Gold vertical separator -->
  <rect x="27" y="9" width="1.8" height="28" rx="0.9" fill="#C8A951"/>

  <!-- S — Space Mono approx via Courier New -->
  <text
    x="31" y="30"
    font-family="'Courier New', 'Space Mono', Courier, monospace"
    font-weight="700"
    font-size="15"
    fill="#267BF1">S</text>
</svg>
